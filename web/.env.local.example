# Copy to .env.local and fill in.

# Required for sessions. Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# Backend API base (server-side proxy target)
API_URL=http://localhost:8000

# --- Google sign-in (optional; guest login works without it) ---
# 1. Google Cloud Console → APIs & Services → Credentials → Create OAuth client (Web).
# 2. Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 3. Paste the client id/secret below and set NEXT_PUBLIC_GOOGLE_ENABLED=true.
NEXT_PUBLIC_GOOGLE_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
